# Firebase web app config — copy this file to .env.local and fill in the values
# from Firebase console → Project settings → Your apps → Web app → SDK setup (Config).
# NEVER commit .env.local.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: set to "true" to point the app at the local Firebase Emulator Suite
# (auth :9099, firestore :8080, functions :5001). Used by `npm run dev:emulators`.
VITE_USE_EMULATORS=false
